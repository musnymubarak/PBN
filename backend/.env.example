# ─── Application ───────────────────────────────────────────
APP_NAME=Prime Business Network
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ─── Security ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=pbn_user
POSTGRES_PASSWORD=pbn_secret_password
POSTGRES_DB=pbn_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pbn_user:pbn_secret_password@localhost:5432/pbn_db

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Bancstac / Paycenter ──────────────────────────────────
BANCSTAC_CLIENT_ID=your_client_id
BANCSTAC_AUTH_TOKEN=your_auth_token
BANCSTAC_HMAC_SECRET=your_hmac_secret
BANCSTAC_API_URL=https://paycorp-cbc.prod.aws.paycorp.lk/rest/service/proxy
BANCSTAC_RETURN_URL=https://yourdomain.com/api/v1/payments/bancstac/return
BANCSTAC_CANCEL_URL=https://yourdomain.com/payment-cancelled

# ─── Firebase ─────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json
